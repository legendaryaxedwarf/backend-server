DISCORD_TOKEN=your_bot_token_here
CHANNEL_ID=123456789012345678

DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=apply_db

# 알림 보낼 시간 (24시간 형식, Asia/Seoul)
NOTIFY_HOUR=9
NOTIFY_MINUTE=0

# 알림 대상 직무 키워드 (쉼표 구분, 비우면 전체)
# 부분일치(LIKE)로 매칭됨. 예: "백엔드" -> "백엔드 개발자", "파이썬 백엔드" 모두 매칭
TARGET_JOB_PARTS=백엔드,프론트엔드
